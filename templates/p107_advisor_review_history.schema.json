{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["review_number", "bundle_path", "verdict_path", "bundle_sha256", "verdict_sha256", "advisor_lineage_id", "advisor_session_id"],
        "properties": {
          "review_number": {"type": "integer", "minimum": 1, "maximum": 3},
          "bundle_path": {"type": "string"},
          "verdict_path": {"type": "string"},
          "bundle_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "verdict_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "prior_verdict_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
          "advisor_lineage_id": {"type": "string"},
          "advisor_session_id": {"type": "string"}
        }
      }
    }
  }
}
