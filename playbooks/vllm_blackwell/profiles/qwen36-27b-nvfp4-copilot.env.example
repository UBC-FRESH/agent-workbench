# Copilot/OpenAI-client compatibility profile for nvidia/Qwen3.6-27B-NVFP4.
# Keeps the fast stable kernels, but disables Qwen thinking output so clients get
# normal `message.content` / `delta.content` instead of `reasoning` fields.
#
# Usage from lab root:
#   VLLM_ENV_FILE=profiles/qwen36-27b-nvfp4-copilot.env.example ./scripts/serve-native.sh

VLLM_SHARED_CACHE=/srv/shared-data/vllm
VLLM_SECRETS_ENV=/srv/shared-data/vllm/secrets.env
HF_HOME=/srv/shared-data/vllm/huggingface
HUGGINGFACE_HUB_CACHE=/srv/shared-data/vllm/huggingface/hub
VLLM_CACHE_ROOT=/srv/shared-data/vllm/vllm-cache
FLASHINFER_WORKSPACE_BASE=/srv/shared-data/vllm/flashinfer
FLASHINFER_WORKSPACE_DIR=/srv/shared-data/vllm/flashinfer
TMPDIR=/srv/shared-data/vllm/tmp

VLLM_HOST=0.0.0.0
VLLM_PORT=18000
VLLM_MODEL=nvidia/Qwen3.6-27B-NVFP4
VLLM_SERVED_MODEL_NAME=qwen3.6-27b-nvfp4
VLLM_TOKENIZER=

VLLM_MAX_MODEL_LEN=262144
VLLM_GPU_MEMORY_UTILIZATION=0.50
VLLM_MAX_NUM_SEQS=8
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_GENERATION_CONFIG=vllm

VLLM_TRUST_REMOTE_CODE=1
VLLM_KV_CACHE_DTYPE=bfloat16
VLLM_ENABLE_PREFIX_CACHING=1
VLLM_ENABLE_CHUNKED_PREFILL=1
VLLM_ASYNC_SCHEDULING=1
VLLM_REASONING_PARSER=
VLLM_ENABLE_AUTO_TOOL_CHOICE=1
VLLM_TOOL_CALL_PARSER=qwen3_xml
VLLM_SPECULATIVE_CONFIG='{"method":"mtp","num_speculative_tokens":1}'

VLLM_QUANTIZATION=
VLLM_ATTENTION_BACKEND=FLASH_ATTN
VLLM_LINEAR_BACKEND=marlin
VLLM_TEST_FORCE_FP8_MARLIN=1
VLLM_MOE_BACKEND=
VLLM_GDN_PREFILL_BACKEND=triton
VLLM_MM_ENCODER_ATTN_BACKEND=FLASH_ATTN
VLLM_LOAD_FORMAT=
VLLM_DTYPE=
VLLM_LANGUAGE_MODEL_ONLY=0
VLLM_DEFAULT_CHAT_TEMPLATE_KWARGS='{"enable_thinking": false}'
VLLM_MM_ENCODER_TP_MODE=
VLLM_MM_PROCESSOR_CACHE_TYPE=

VLLM_SLEEP_WHEN_IDLE=1
VLLM_LOG_STATS_INTERVAL=1
HF_TOKEN=
